{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities for the main window: core events + the supervised collector sidecar.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [{ "name": "binaries/collector", "sidecar": true, "args": ["serve"] }]
    },
    "shell:allow-stdin-write",
    "shell:allow-kill",
    "updater:default",
    "process:allow-restart"
  ]
}
