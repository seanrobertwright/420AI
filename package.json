{
  "name": "420ai",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "typecheck": "tsc -b",
    "build": "tsc -b",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,md}\"",
    "repo-health": "node scripts/repo-health.mjs",
    "repo-health:fast": "node scripts/repo-health.mjs --fast",
    "prepare": "git config core.hooksPath .githooks",
    "setup": "node scripts/setup-env.mjs",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:generate": "npm run -w @420ai/db db:generate",
    "db:migrate": "npm run -w @420ai/db db:migrate",
    "db:rotate-key": "npm run -w @420ai/db db:rotate-key",
    "db:reprice": "npm run -w @420ai/db db:reprice",
    "db:reparse": "npm run -w @420ai/db db:reparse",
    "db:rollback": "npm run -w @420ai/db db:rollback",
    "backup": "sh scripts/backup-archive.sh",
    "restore": "sh scripts/restore-archive.sh",
    "reports:generate": "node scripts/generate-reports.mjs",
    "ingest:dev": "npm run -w @420ai/ingest dev",
    "dashboard:dev": "npm run -w @420ai/dashboard dev",
    "typecheck:dashboard": "npm run typecheck -w @420ai/dashboard",
    "build:dashboard": "npm run build -w @420ai/dashboard",
    "typecheck:desktop": "npm run typecheck -w @420ai/desktop",
    "build:collector-sea": "node apps/collector/scripts/build-sea.mjs",
    "build:desktop": "npm run build:collector-sea && npm run build -w @420ai/desktop && cd apps/desktop && cargo tauri build"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24",
    "esbuild": "^0.28",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "globals": "^15.15.0",
    "postject": "^1.0.0-alpha.6",
    "prettier": "^3.8.4",
    "tsx": "^4",
    "typescript": "^6",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4"
  }
}
