{
  "name": "420ai",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "typecheck": "tsc -b",
    "build": "tsc -b",
    "test": "vitest run",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:generate": "npm run -w @420ai/db db:generate",
    "db:migrate": "npm run -w @420ai/db db:migrate",
    "ingest:dev": "npm run -w @420ai/ingest dev"
  },
  "devDependencies": {
    "@types/node": "^24",
    "tsx": "^4",
    "typescript": "^6",
    "vitest": "^4"
  }
}
