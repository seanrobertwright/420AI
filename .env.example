# Milestone 2 environment — copy to .env and fill the two secrets.
#   cp .env.example .env
# .env is gitignored; only this template is committed. NEVER commit a real key.

# Central Archive connection (dev database). Host port 5433 — see docker-compose.yml.
DATABASE_URL=postgres://420ai:420ai@localhost:5433/420ai

# Test database (same server, separate DB). Integration tests self-skip if unset.
DATABASE_URL_TEST=postgres://420ai:420ai@localhost:5433/420ai_test

# Field-level encryption key — 32 bytes, base64-encoded. Held by the app, NEVER
# stored in the DB (PRD §18.1). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ARCHIVE_ENCRYPTION_KEY=

# Admin token gating POST /v1/pairing-codes (temporary M2 affordance — the
# dashboard issues codes in a later milestone). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
ADMIN_TOKEN=

# Port the ingest API listens on.
INGEST_PORT=8420

# --- M8 AI Interpretation Pipeline (PRD §16.2) ---
# Configures the Analysis Provider behind POST /v1/sessions/:id/interpretations and
# POST /v1/projects/:id/interpretations. Leaving ANALYSIS_PROVIDER / ANALYSIS_API_KEY
# UNSET keeps the rest of the API fully working; only the interpretation endpoints
# return 503 ("analysis provider not configured"). Redaction runs before anything is
# sent to the provider or stored, so secrets never leave the archive.
#
# Provider: "anthropic" (Anthropic Messages API, default) or "openai" (OpenAI-compatible
# Chat Completions — Ollama / LM Studio / vLLM / OpenAI).
ANALYSIS_PROVIDER=anthropic
# Your provider API key (Anthropic key for "anthropic"; the bearer key for "openai").
ANALYSIS_API_KEY=
# Model id. For Anthropic, a current balance-tier model (verify against the latest
# Claude model ids); for an OpenAI-compatible endpoint, that endpoint's model name.
ANALYSIS_MODEL=claude-sonnet-4-6
# OpenAI-compatible providers only — the base URL (e.g. http://localhost:11434/v1 for
# Ollama). Leave blank for Anthropic (it uses the fixed Messages API endpoint).
ANALYSIS_BASE_URL=
# Max output tokens for one interpretation call.
ANALYSIS_MAX_OUTPUT_TOKENS=4096
# Per-call request timeout (ms).
ANALYSIS_TIMEOUT_MS=60000

# --- M9 Live Monitor (PRD §8.4, §20) ---
# SSE push cadence for GET /v1/monitor/stream (ms). Optional — defaults to 3000.
MONITOR_STREAM_INTERVAL_MS=3000
# Collector heartbeat cadence (ms). Optional — the `collector watch` daemon sends a
# best-effort liveness ping (sync backlog + version) on this cadence; defaults to 30000.
# Override per-run with `collector watch --heartbeat-interval <ms>`.
HEARTBEAT_INTERVAL_MS=30000

# --- M9 dashboard (apps/dashboard, Next.js) ---
# Where the dashboard's server-side proxy reaches the ingest API. The browser NEVER
# sees ADMIN_TOKEN — Server Components / Route Handlers add it on the server→ingest hop.
INGEST_URL=http://localhost:8420
# The dashboard REUSES ADMIN_TOKEN (above) to authenticate to GET /v1/monitor[/stream].
# Never expose it via a NEXT_PUBLIC_* var.
