# Milestone 2 environment — copy to .env and fill the two secrets.
#   cp .env.example .env
# .env is gitignored; only this template is committed. NEVER commit a real key.

# Central Archive connection (dev database). Host port 5433 — see docker-compose.yml.
DATABASE_URL=postgres://420ai:420ai@localhost:5433/420ai

# Test database (same server, separate DB). Integration tests self-skip if unset.
DATABASE_URL_TEST=postgres://420ai:420ai@localhost:5433/420ai_test

# Field-level encryption key — 32 bytes, base64-encoded. Held by the app, NEVER
# stored in the DB (PRD §18.1). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ARCHIVE_ENCRYPTION_KEY=

# --- M12 12.4e key rotation (OPTIONAL keyring mode) ---
# ARCHIVE_ENCRYPTION_KEY (above, single key) remains the default and is byte-for-byte
# unchanged. To ROTATE the key, switch to a keyring: a JSON map of keyId→base64-key plus the
# active keyId. The keyId rides inside each ciphertext, so old + new keys coexist while
# `npm run db:rotate-key` re-encrypts every row. Carry the OLD key in the keyring until
# rotation completes, then it may be removed. Full procedure: docs/guide/operations.md.
#   ARCHIVE_ENCRYPTION_KEYS={"legacy":"<old-b64>","v2":"<new-b64>"}
#   ARCHIVE_ENCRYPTION_ACTIVE_KEY_ID=v2
ARCHIVE_ENCRYPTION_KEYS=
ARCHIVE_ENCRYPTION_ACTIVE_KEY_ID=

# MACHINE / SERVICE token (M12 12.3): the long-lived shared secret used by the desktop
# app + collector CLI to authenticate to the ingest admin surface (pairing-code issuance,
# ingest, etc.). It is NO LONGER a human credential — the dashboard uses a real login
# (see "Admin login" below) and never holds this token. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
ADMIN_TOKEN=

# --- Admin login (M12 12.3) ---
# A real single-user admin login for the dashboard. POST /v1/auth/login verifies the
# password (scrypt) and issues a stateless HMAC session token; the dashboard stores it in
# an httpOnly cookie and its middleware verifies it on every request.
#
# Single-admin email. Optional — defaults to seanrobertwright@gmail.com (the legacy
# single-user identity) when unset, so existing data keeps resolving the same user.
ADMIN_EMAIL=
# Admin password. Seeded → scrypt-hashed into the users table on EVERY ingest boot, so
# rotating it == change this value + restart. If UNSET, login is disabled (the API still
# works via ADMIN_TOKEN for machine clients), and ingest logs a one-line warning.
ADMIN_PASSWORD=
# HMAC key that signs/verifies session tokens. REQUIRED (ingest refuses to boot without it).
# MUST be set IDENTICALLY for BOTH the ingest process AND the dashboard — the dashboard
# middleware verifies the cookie with this same secret (a mismatch fails every login).
# Rotating it invalidates all live sessions ("revoke all"). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
SESSION_SECRET=

# Port the ingest API listens on.
INGEST_PORT=8420

# --- M8 AI Interpretation Pipeline (PRD §16.2) ---
# Configures the Analysis Provider behind POST /v1/sessions/:id/interpretations and
# POST /v1/projects/:id/interpretations. Leaving ANALYSIS_PROVIDER / ANALYSIS_API_KEY
# UNSET keeps the rest of the API fully working; only the interpretation endpoints
# return 503 ("analysis provider not configured"). Redaction runs before anything is
# sent to the provider or stored, so secrets never leave the archive.
#
# Provider: "anthropic" (Anthropic Messages API, default) or "openai" (OpenAI-compatible
# Chat Completions — Ollama / LM Studio / vLLM / OpenAI).
ANALYSIS_PROVIDER=anthropic
# Your provider API key (Anthropic key for "anthropic"; the bearer key for "openai").
ANALYSIS_API_KEY=
# Model id. For Anthropic, a current balance-tier model (verify against the latest
# Claude model ids); for an OpenAI-compatible endpoint, that endpoint's model name.
ANALYSIS_MODEL=claude-sonnet-4-6
# OpenAI-compatible providers only — the base URL (e.g. http://localhost:11434/v1 for
# Ollama). Leave blank for Anthropic (it uses the fixed Messages API endpoint).
ANALYSIS_BASE_URL=
# Max output tokens for one interpretation call.
ANALYSIS_MAX_OUTPUT_TOKENS=4096
# Per-call request timeout (ms).
ANALYSIS_TIMEOUT_MS=60000

# --- M9 Live Monitor (PRD §8.4, §20) ---
# SSE push cadence for GET /v1/monitor/stream (ms). Optional — defaults to 3000.
MONITOR_STREAM_INTERVAL_MS=3000
# Collector heartbeat cadence (ms). Optional — the `collector watch` daemon sends a
# best-effort liveness ping (sync backlog + version) on this cadence; defaults to 30000.
# Override per-run with `collector watch --heartbeat-interval <ms>`.
HEARTBEAT_INTERVAL_MS=30000

# --- M12 12.6 alert delivery (PRD §20) ---
# POST the firing JSON to this webhook when an operational alert newly opens (Slack/Discord/
# n8n/email-bridge). UNSET = delivery disabled (the firing still shows in the dashboard — the
# webhook is a convenience push, not the durable record). At-most-one ATTEMPT per firing.
ALERT_WEBHOOK_URL=
# Per-delivery request timeout (ms). Optional — defaults to 5000.
ALERT_WEBHOOK_TIMEOUT_MS=5000

# --- M12 12.4b observability ---
# Structured-logging level for the ingest server (pino): trace|debug|info|warn|error|fatal.
# The authorization + cookie headers are always redacted from logs regardless of level.
LOG_LEVEL=info

# --- M12 12.4c rate limiting ---
# Rate limiting is ON by default; set RATE_LIMIT_ENABLED=false to disable entirely. The global
# limit is generous (the ingest hot path); the login limit is the brute-force guard on
# POST /v1/auth/login. timeWindow accepts @fastify/rate-limit durations ("1 minute", "15 minutes").
RATE_LIMIT_ENABLED=true
RATE_LIMIT_GLOBAL_MAX=1000
RATE_LIMIT_WINDOW=1 minute
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_LOGIN_WINDOW=15 minutes

# --- M12 12.4d backups ---
# Where `npm run backup` writes timestamped gzipped pg_dumps, and how many days of dump FILES
# to keep (older dumps are pruned; DB rows are never touched — raw_source_records is sacred).
BACKUP_DIR=./backups
RETENTION_DAYS=14

# --- M9 dashboard (apps/dashboard, Next.js) ---
# Where the dashboard's server-side proxy reaches the ingest API. The browser NEVER holds
# any credential — Server Components / Route Handlers add the admin's session-token bearer
# on the server→ingest hop.
INGEST_URL=http://localhost:8420
# M12 12.3: the dashboard NO LONGER reads ADMIN_TOKEN. It needs SESSION_SECRET (above) —
# the SAME value as the ingest process — so its middleware can verify the login cookie.
# Never expose SESSION_SECRET via a NEXT_PUBLIC_* var.
