vendor/

# Build output
dist/
build/
out/
.next/
target/
*.tsbuildinfo

# Tauri / Rust
src-tauri/target/
**/*.rs.bk
# Machine-local Cargo config (redirects target-dir out of OneDrive — see the file's header)
apps/desktop/src-tauri/.cargo/

# Environment & secrets
.env
.env.*
!.env.example
*.pem
*.key
secrets/
.secrets/

# Supabase / Docker local data
supabase/.branches/
supabase/.temp/
**/volumes/db/data/
*.sqlite
*.db

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test & coverage
coverage/
.nyc_output/

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp

# Exports / generated artifacts
exports/
*.parquet
.gstack/

# M12 12.4d archive backups — dumps contain ciphertext + plaintext metadata; NEVER commit.
backups/

# M14 raw chat exports (OpenAI/Gemini/Claude data-export dumps used to derive parser field maps).
# These carry full conversation bodies + personal reasoning (PII); only the REDACTED fixtures under
# packages/shared/src/parsers/fixtures/ are committed. NEVER commit the raw exports.
docs/data/

# Windows service (WinSW): the third-party wrapper + the copied collector binary are large and not
# ours to vendor — only the .xml + README under apps/collector/service/ are committed.
apps/collector/service/*.exe

# Local UAT run artifacts — login*.json hold test credentials; UAT.md is a generated working
# checklist (uat-events.parquet is already covered by *.parquet above). Never commit these.
/login.json
/login-bad.json
/UAT.md
